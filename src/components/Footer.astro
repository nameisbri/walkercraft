---
const serviceAreas = ["Hamilton", "Burlington", "Oakville", "Ancaster", "Dundas", "Stoney Creek"];
const currentYear = new Date().getFullYear();
---

<footer class="bg-bark text-warmgray-500 py-16 border-t border-white/5">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 md:grid-cols-[1.5fr_1fr_1fr] gap-10">
      <div>
        <p class="font-display text-2xl text-gold-light mb-3">Walkercraft</p>
        <p class="text-sm leading-relaxed max-w-xs">
          Custom carpentry &amp; handyman services for homeowners across the Greater Toronto and Hamilton Area.
        </p>
      </div>

      <div>
        <h3 class="text-white text-xs font-semibold tracking-widest uppercase mb-4">Service Areas</h3>
        <ul class="space-y-1.5 text-sm">
          {serviceAreas.map((area) => (
            <li>{area}</li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-white text-xs font-semibold tracking-widest uppercase mb-4">Contact</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="tel:+15551234567" class="hover:text-gold-light transition-colors">(555) 123-4567</a>
          </li>
          <li>
            <a href="mailto:brett@walkercraft.ca" class="hover:text-gold-light transition-colors">brett@walkercraft.ca</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/5 mt-12 pt-6 text-xs text-warmgray-600">
      <p>&copy; {currentYear} Walkercraft. All rights reserved.</p>
    </div>
  </div>
</footer>
