---
import { getCMSContent, cms } from '@lib/cms';
const c = await getCMSContent();

const serviceAreas = [
  { name: "Hamilton", slug: "hamilton" },
  { name: "Burlington", slug: "burlington" },
  { name: "Oakville", slug: "oakville" },
  { name: "Ancaster", slug: "ancaster" },
  { name: "Dundas", slug: "dundas" },
  { name: "Stoney Creek", slug: "stoney-creek" },
];
const currentYear = new Date().getFullYear();
---

<footer class="bg-bark text-warmgray-500 py-16 border-t border-white/5">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 md:grid-cols-[1.5fr_1fr_1fr] gap-10">
      <div>
        <p class="font-display text-2xl text-gold-light mb-3">Walkercraft Carpentry</p>
        <p class="text-sm leading-relaxed max-w-xs">
          Custom carpentry &amp; handyman services for homeowners across the Greater Toronto and Hamilton Area.
        </p>
      </div>

      <nav aria-label="Service areas">
        <h3 class="text-white text-xs font-semibold tracking-widest uppercase mb-4">Serving</h3>
        <ul class="space-y-1.5 text-sm">
          {serviceAreas.map((area) => (
            <li>
              <a href={`/${area.slug}/`} class="underline decoration-white/20 underline-offset-2 hover:text-gold-light hover:decoration-gold-light/40 transition-colors">
                {area.name}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <nav aria-label="Contact information">
        <h3 class="text-white text-xs font-semibold tracking-widest uppercase mb-4">Contact</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="tel:+12267896525" class="underline decoration-white/20 underline-offset-2 hover:text-gold-light hover:decoration-gold-light/40 transition-colors">{cms(c, 'phone', '(226) 789-6525')}</a>
          </li>
          <li>
            <a href="mailto:info@walkercraftcarpentry.ca" class="underline decoration-white/20 underline-offset-2 hover:text-gold-light hover:decoration-gold-light/40 transition-colors">{cms(c, 'email', 'info@walkercraftcarpentry.ca')}</a>
          </li>
        </ul>
      </nav>
    </div>

    <div class="border-t border-white/5 mt-12 pt-6 text-xs text-warmgray-500">
      <p>&copy; {currentYear} Walkercraft Carpentry. All rights reserved.</p>
    </div>
  </div>
</footer>
