---
// Lightbox component — client-side only, no props needed.
// Activated via data-lightbox attributes on gallery images.
---

<!-- Lightbox overlay -->
<div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 backdrop-blur-sm" role="dialog" aria-modal="true" aria-label="Image lightbox">
  <!-- Close button -->
  <button id="lb-close" class="absolute top-4 right-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white transition hover:bg-white/20 focus:outline-none focus-visible:ring-2 focus-visible:ring-gold" aria-label="Close lightbox">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>

  <!-- Previous button -->
  <button id="lb-prev" class="absolute left-2 sm:left-4 top-1/2 z-10 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white transition hover:bg-white/20 focus:outline-none focus-visible:ring-2 focus-visible:ring-gold" aria-label="Previous image">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  </button>

  <!-- Next button -->
  <button id="lb-next" class="absolute right-2 sm:right-4 top-1/2 z-10 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white transition hover:bg-white/20 focus:outline-none focus-visible:ring-2 focus-visible:ring-gold" aria-label="Next image">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
  </button>

  <!-- Image container -->
  <div class="flex h-full w-full items-center justify-center p-4 sm:p-12 md:p-16">
    <img id="lb-img" src="" alt="" class="max-h-full max-w-full rounded-sm object-contain select-none" draggable="false" />
  </div>

  <!-- Caption -->
  <div id="lb-caption" class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent px-6 pb-5 pt-10 text-center">
    <p id="lb-caption-text" class="font-display text-lg text-white"></p>
    <p id="lb-counter" class="mt-1 text-xs text-warmgray-500"></p>
  </div>
</div>

<script>
  const lightbox = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  const lbCaption = document.getElementById('lb-caption-text')!;
  const lbCounter = document.getElementById('lb-counter')!;
  const btnClose = document.getElementById('lb-close')!;
  const btnPrev = document.getElementById('lb-prev')!;
  const btnNext = document.getElementById('lb-next')!;

  let items: { src: string; alt: string; caption: string }[] = [];
  let currentIndex = 0;
  let previouslyFocused: HTMLElement | null = null;

  function collectItems() {
    items = [];
    document.querySelectorAll('[data-lightbox]').forEach((el) => {
      const img = el.querySelector('img');
      if (!img) return;
      // Get the largest srcset source or fall back to src
      const srcset = img.getAttribute('srcset');
      let src = img.src;
      if (srcset) {
        const sources = srcset.split(',').map(s => s.trim());
        const last = sources[sources.length - 1];
        if (last) src = last.split(/\s+/)[0];
      }
      items.push({
        src,
        alt: img.alt || '',
        caption: el.getAttribute('data-caption') || '',
      });
    });
  }

  function show(index: number) {
    if (items.length === 0) return;
    currentIndex = ((index % items.length) + items.length) % items.length;
    const item = items[currentIndex];
    lbImg.src = item.src;
    lbImg.alt = item.alt;
    lbCaption.textContent = item.caption;
    lbCounter.textContent = `${currentIndex + 1} / ${items.length}`;
  }

  function open(index: number) {
    collectItems();
    previouslyFocused = document.activeElement as HTMLElement;
    show(index);
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
    btnClose.focus();
  }

  function close() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
    if (previouslyFocused) previouslyFocused.focus();
  }

  // Attach click handlers to gallery items
  function attachHandlers() {
    document.querySelectorAll('[data-lightbox]').forEach((el, i) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        open(i);
      });
      // Make keyboard accessible
      if (!el.getAttribute('tabindex')) el.setAttribute('tabindex', '0');
      el.setAttribute('role', 'button');
      el.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
          e.preventDefault();
          open(i);
        }
      });
    });
  }

  btnClose.addEventListener('click', close);
  btnPrev.addEventListener('click', () => show(currentIndex - 1));
  btnNext.addEventListener('click', () => show(currentIndex + 1));

  // Click outside image to close
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox || (e.target as HTMLElement).closest('#lb-caption')) {
      close();
    }
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') show(currentIndex - 1);
    if (e.key === 'ArrowRight') show(currentIndex + 1);
  });

  // Touch swipe support
  let touchStartX = 0;
  lightbox.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].clientX;
  }, { passive: true });
  lightbox.addEventListener('touchend', (e) => {
    const diff = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) show(currentIndex - 1);
      else show(currentIndex + 1);
    }
  }, { passive: true });

  attachHandlers();
</script>
