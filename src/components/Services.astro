---
const services = [
  {
    number: "01",
    title: "Custom Carpentry",
    description: "Precision woodwork tailored to your space.",
    items: ["Built-in cabinetry", "Crown moulding & trim", "Custom shelving & storage"],
  },
  {
    number: "02",
    title: "Exterior Work",
    description: "Built to withstand Canadian weather.",
    items: ["Deck building & repair", "Fence installation", "Exterior repairs & siding"],
  },
  {
    number: "03",
    title: "General Handyman",
    description: "No job too small. Get it done right.",
    items: ["Drywall patching & repair", "Fixture installation", "General maintenance"],
  },
];
---

<section id="services" class="py-20 md:py-32 bg-parchment">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <p class="text-gold font-semibold text-sm tracking-widest uppercase mb-4">Services</p>
    <h2 class="font-display text-4xl md:text-5xl mb-16 max-w-lg">What We Do</h2>

    <div class="space-y-0">
      {services.map((service, i) => (
        <div class:list={[
          "grid grid-cols-1 md:grid-cols-[4rem_1fr_1fr] gap-4 md:gap-8 py-10",
          i < services.length - 1 && "border-b border-warmgray-300",
        ]}>
          <p class="font-display text-3xl text-warmgray-300 hidden md:block">{service.number}</p>
          <div>
            <h3 class="font-display text-2xl md:text-3xl mb-2">{service.title}</h3>
            <p class="text-warmgray-600 leading-relaxed">{service.description}</p>
          </div>
          <ul class="space-y-2 md:pt-1">
            {service.items.map((item) => (
              <li class="flex items-start gap-3 text-warmgray-700">
                <span class="block w-1.5 h-1.5 rounded-full bg-gold mt-2 shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
