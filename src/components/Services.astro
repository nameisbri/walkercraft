---
import { getCMSContent, cms } from '@lib/cms';
const c = await getCMSContent();

const services = [
  {
    number: "01",
    title: cms(c, 'service_1_title', "Custom Carpentry"),
    description: cms(c, 'service_1_description', "Shelves, cabinets, trim — built to fit your house."),
    items: ["Built-in cabinetry", "Crown moulding & trim", "Custom shelving & storage"],
    color: "rust",
  },
  {
    number: "02",
    title: cms(c, 'service_2_title', "Exterior Work"),
    description: cms(c, 'service_2_description', "Built to withstand Canadian weather."),
    items: ["Deck building & repair", "Fence installation", "Exterior repairs & siding"],
    color: "forest",
  },
  {
    number: "03",
    title: cms(c, 'service_3_title', "General Handyman"),
    description: cms(c, 'service_3_description', "The stuff you keep putting off. I'll take care of it."),
    items: ["Drywall patching & repair", "Fixture installation", "General maintenance"],
    color: "gold",
  },
];

const dotColors: Record<string, string> = {
  rust: "bg-rust",
  forest: "bg-forest",
  gold: "bg-gold",
};

const numColors: Record<string, string> = {
  rust: "text-rust/30",
  forest: "text-forest/30",
  gold: "text-gold-light/30",
};

const borderColors: Record<string, string> = {
  rust: "border-rust/20",
  forest: "border-forest/20",
  gold: "border-gold/20",
};
---

<section id="services" class="py-20 md:py-32 bg-parchment">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <h2 class="font-display text-4xl md:text-5xl mb-16 max-w-lg">{cms(c, 'services_heading', 'What We Do')}</h2>

    <div class="space-y-0">
      {services.map((service, i) => (
        <div class:list={[
          "grid grid-cols-1 md:grid-cols-[4rem_1fr_1fr] gap-4 md:gap-8 py-10",
          i < services.length - 1 ? `border-b ${borderColors[service.color]}` : "",
        ]}>
          <p class:list={["font-display text-3xl hidden md:block", numColors[service.color]]}>{service.number}</p>
          <div>
            <h3 class="font-display text-2xl md:text-3xl mb-2">{service.title}</h3>
            <p class="text-warmgray-600 leading-relaxed">{service.description}</p>
          </div>
          <ul class="space-y-2 md:pt-1">
            {service.items.map((item) => (
              <li class="flex items-start gap-3 text-warmgray-700">
                <span class:list={["block w-1.5 h-1.5 rounded-full mt-2 shrink-0", dotColors[service.color]]}></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
