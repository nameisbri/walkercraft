import frontPorchNight from "../assets/images/front-porch-night.jpg";

const featured = {
  caption: "Coffered ceiling — Hamilton",
  tag: "Carpentry",
  image: cofferedCeiling,
  alt: "Custom coffered ceiling with trim work installed by Walkercraft Carpentry in Hamilton",
};

const topProjects = [
  {
    caption: "Fireplace surround — Hamilton",
    tag: "Carpentry",
    image: fireplaceSurround,
