    caption: "Mantel clock — handmade",
    tag: "Woodworking",
    image: mantelClock,
    alt: "Handmade cedar mantel clock by Walkercraft Carpentry",
  },
  {
    caption: "Paddle carving — in progress",
    tag: "Woodworking",
    image: canoePaddlesWorkshop,
    alt: "Canoe paddles being hand-carved in the workshop by Walkercraft Carpentry",
  },
  {
    caption: "Custom shelf build",
    tag: "Woodworking",
    image: customShelfBuild,
    alt: "Custom birch plywood floating shelf on workbench by Walkercraft Carpentry",
  },
];

const photoCount = 1 + topProjects.length + galleryProjects.length + 2; // +2 for the before/after pair
---

<section id="projects" class="relative py-20 md:py-32 bg-bark text-white overflow-hidden grain">
  <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-14 md:mb-16 gap-4">
      <h2 class="font-display text-4xl md:text-5xl">{cms(c, 'projects_heading', 'Our Work')}</h2>
      <p class="text-warmgray-500 text-sm">{cms(c, 'projects_subtitle', '50+ projects across the GTHA')}</p>
    </div>

    <!-- Bento grid: featured large left, 2 stacked right, 3 across bottom -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-3">

      <!-- Featured project: spans 2 cols + 2 rows -->
      <div
        class="group relative col-span-2 row-span-2 rounded-sm overflow-hidden border border-white/10 cursor-pointer"
        data-lightbox
        data-caption={featured.caption}
      >
        <div class="aspect-[4/3] md:aspect-auto md:h-full">
          <Image
            src={featured.image}
            alt={featured.alt}
            widths={[400, 800, 1200]}
            sizes="(max-width: 768px) 100vw, 50vw"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-bark/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-5 md:p-8">
            <span class="text-xs font-semibold tracking-widest uppercase text-gold mb-2">{featured.tag}</span>
            <p class="font-display text-xl md:text-2xl">{featured.caption}</p>
          </div>
        </div>
      </div>

      <!-- Right column: 2 stacked images -->
      {topProjects.slice(0, 2).map((project) => (
        <div
          class="group relative col-span-1 rounded-sm overflow-hidden border border-white/10 cursor-pointer"
          data-lightbox
          data-caption={project.caption}
        >
          <div class="aspect-[4/3] relative">
            <Image
              src={project.image}
              alt={project.alt}
              widths={[300, 600]}
              sizes="(max-width: 768px) 50vw, 25vw"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-bark/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-3 md:p-4">
              <span class="text-[10px] font-semibold tracking-widest uppercase text-gold mb-1">{project.tag}</span>
              <p class="text-sm font-display">{project.caption}</p>
            </div>
          </div>
        </div>
      ))}

    </div>

    <!-- Bottom row of top projects -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-2 md:gap-3 mt-2 md:mt-3">
      {topProjects.slice(2).map((project) => (
        <div
          class="group relative rounded-sm overflow-hidden border border-white/10 cursor-pointer"
          data-lightbox
          data-caption={project.caption}
        >
          <div class="aspect-[3/2] relative">
            <Image
              src={project.image}
              alt={project.alt}
              widths={[300, 600]}
              sizes="(max-width: 768px) 50vw, 33vw"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-bark/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-3 md:p-4">
              <span class="text-[10px] font-semibold tracking-widest uppercase text-gold mb-1">{project.tag}</span>
              <p class="text-sm font-display">{project.caption}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Extended gallery -->
    <div class="mt-12 md:mt-16">
      <h3 class="font-display text-2xl md:text-3xl mb-8">{cms(c, 'projects_gallery_heading', 'More Projects')}</h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2 md:gap-3">
        {/* First 4 items (treehouse + living wall + arched windows) */}
        {galleryProjects.slice(0, 4).map((project) => (
          <div
            class="group relative rounded-sm overflow-hidden border border-white/10 cursor-pointer"
            data-lightbox
            data-caption={project.caption}
          >
            <div class="aspect-square relative">
              <Image
                src={project.image}
                alt={project.alt}
                widths={[300, 600]}
                sizes="(max-width: 640px) 50vw, (max-width: 768px) 33vw, 25vw"
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-bark/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-3 md:p-4">
                <span class="text-[10px] font-semibold tracking-widest uppercase text-gold mb-1">{project.tag}</span>
                <p class="text-sm font-display">{project.caption}</p>
              </div>
            </div>
          </div>
        ))}

        {/* Before / After — spans 2 columns */}
        <div class="col-span-2 rounded-sm overflow-hidden border border-white/10">
          <div class="relative">
            <span class="absolute top-2 left-2 z-10 rounded bg-bark/80 px-2 py-0.5 text-[10px] font-semibold tracking-widest uppercase text-gold">{porchGable.tag}</span>
            <p class="absolute top-2 right-2 z-10 rounded bg-bark/80 px-2 py-0.5 text-xs font-display text-white">{porchGable.caption}</p>
            <div class="grid grid-cols-2">
              <div class="relative cursor-pointer group" data-lightbox data-caption="Porch gable — before">
                <div class="aspect-square relative">
                  <Image
                    src={porchGable.before.image}
                    alt={porchGable.before.alt}
                    widths={[300, 600]}
                    sizes="(max-width: 640px) 50vw, 25vw"
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                  <span class="absolute bottom-2 left-2 rounded bg-bark/80 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-warmgray-300" aria-hidden="true">Before</span>
                </div>
              </div>
              <div class="relative cursor-pointer group" data-lightbox data-caption="Porch gable — after">
                <div class="aspect-square relative">
                  <Image
                    src={porchGable.after.image}
                    alt={porchGable.after.alt}
                    widths={[300, 600]}
                    sizes="(max-width: 640px) 50vw, 25vw"
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                  <span class="absolute bottom-2 left-2 rounded bg-gold/90 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-bark" aria-hidden="true">After</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Remaining gallery items */}
        {galleryProjects.slice(4).map((project) => (
          <div
            class="group relative rounded-sm overflow-hidden border border-white/10 cursor-pointer"
            data-lightbox
            data-caption={project.caption}
          >
            <div class="aspect-square relative">
              <Image
                src={project.image}
                alt={project.alt}
                widths={[300, 600]}
                sizes="(max-width: 640px) 50vw, (max-width: 768px) 33vw, 25vw"
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-bark/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-3 md:p-4">
                <span class="text-[10px] font-semibold tracking-widest uppercase text-gold mb-1">{project.tag}</span>
                <p class="text-sm font-display">{project.caption}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <Lightbox />
</section>
