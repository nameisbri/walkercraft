---
const projects = [
  { caption: "Custom built-ins — Hamilton", tall: true },
  { caption: "Deck build — Ancaster", tall: false },
  { caption: "Crown moulding — Burlington", tall: false },
  { caption: "Fence installation — Dundas", tall: false },
  { caption: "Kitchen shelving — Oakville", tall: false },
  { caption: "Exterior repair — Stoney Creek", tall: true },
];
---

<section id="projects" class="relative py-20 md:py-32 bg-bark text-white overflow-hidden grain">
  <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
    <h2 class="font-display text-4xl md:text-5xl mb-12">Our Work</h2>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
      {projects.map((project) => (
        <div
          class:list={[
            "group relative rounded-sm overflow-hidden border border-white/10",
            project.tall ? "row-span-2 aspect-[3/5]" : "aspect-[4/3]",
          ]}
        >
          <!-- Placeholder: Replace with <img> -->
          <div class="absolute inset-0 bg-bark-light flex items-center justify-center">
            <p class="text-warmgray-500 text-xs tracking-wide uppercase">{project.caption}</p>
          </div>

          <!-- Hover overlay -->
          <div class="absolute inset-0 bg-bark/70 opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex items-end p-4">
            <p class="text-sm text-warmgray-300">{project.caption}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
