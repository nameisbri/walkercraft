  },
  {
    caption: "Front porch build — Hamilton",
    tag: "Exterior",
    image: frontPorchDeck,
    alt: "Cedar front porch deck built by Walkercraft Carpentry in Hamilton",
  },
  {
    caption: "Wall panelling — Burlington",
    tag: "Carpentry",
    image: wallPanelling,
    alt: "Custom wall panelling and wainscoting installed by Walkercraft Carpentry in Burlington",
  },
  {
    caption: "Porch columns & soffit — Ancaster",
    tag: "Exterior",
    image: porchRestoration,
    alt: "Porch column and soffit restoration by Walkercraft Carpentry in Ancaster",
  },
  {
    caption: "Ceiling & trim renovation — Hamilton",
    tag: "Carpentry",
    image: ceilingTrimRenovation,
    alt: "Wood plank ceiling with crown moulding and exposed brick renovation by Walkercraft Carpentry",
  },
];

// Before/after pair (rendered specially in the template)
const porchGable = {
  caption: "Porch gable — before & after",
  tag: "Exterior",
  before: { image: porchGableBefore, alt: "Porch gable before renovation by Walkercraft Carpentry" },
  after: { image: porchGableAfter, alt: "Porch gable after cedar siding restoration by Walkercraft Carpentry" },
};

const galleryProjects = [
  {
    caption: "Playhouse build — Hamilton",
    tag: "Exterior",
    image: playhouseFront,
    alt: "Custom children's playhouse with elevated deck and storage by Walkercraft Carpentry",
  },
  {
    caption: "Playhouse — side view",
    tag: "Exterior",
    image: playhouseSide,
    alt: "Custom playhouse with stairs and storage door by Walkercraft Carpentry",
  },
  {
    caption: "Living wall — commercial",
    tag: "Commercial",
    image: livingWall,
    alt: "Reclaimed wood living wall installation with plants by Walkercraft Carpentry",
  },
  {
    caption: "Arched window trim — Hamilton",
    tag: "Commercial",
    image: commercialArchedWindows,
    alt: "Commercial space with arched window trim and exposed brick by Walkercraft Carpentry",
  },
  {
    caption: "Wood plank ceiling — Hamilton",
    tag: "Carpentry",
    image: woodCeilingBrick,
    alt: "Wood plank ceiling with crown moulding and exposed brick by Walkercraft Carpentry",
  },
  {
    caption: "Coffered ceiling detail — Hamilton",
    tag: "Carpentry",
    image: cofferedCeilingDetail,
    alt: "Coffered ceiling trim detail by Walkercraft Carpentry",
  },
  {
    caption: "Window trim & beams — Hamilton",
    tag: "Commercial",
    image: windowTrimBrick,
    alt: "Custom window trim with exposed brick and timber beams by Walkercraft Carpentry",
  },
  {
    caption: "White wainscoting — Burlington",
    tag: "Carpentry",
    image: whiteWainscoting,
    alt: "Full wall white wainscoting panelling by Walkercraft Carpentry in Burlington",
  },
  {
    caption: "Fireplace built-in — Hamilton",
    tag: "Carpentry",
    image: fireplaceBuiltin,
    alt: "Custom built-in fireplace unit with white cabinets and live-edge mantel by Walkercraft Carpentry",
  },
  {
    caption: "Front porch — evening",
    tag: "Exterior",
    image: frontPorchNight,
    alt: "Cedar front porch deck illuminated at night by Walkercraft Carpentry",
  },
  {
    caption: "Coffered ceiling in progress",
    tag: "Process",
    image: cofferedCeilingProgress,
    alt: "Coffered ceiling construction in progress by Walkercraft Carpentry",
  },
  {
    caption: "Porch columns in progress",
    tag: "Process",
    image: porchColumnsProgress,
    alt: "Porch column wraps and cedar soffit installation in progress by Walkercraft Carpentry",
  },
  {
    caption: "Custom deck stairs — Hamilton",
    tag: "Exterior",
    image: deckStairs,
    alt: "Custom corner wrap deck stairs with metal balusters by Walkercraft Carpentry",
  },
  {
    caption: "Display shelving — retail",
    tag: "Commercial",
    image: displayShelving,
    alt: "Custom A-frame display shelving for retail storefront by Walkercraft Carpentry",
  },
  {
    caption: "Basement built-in — Hamilton",
    tag: "Carpentry",
    image: basementBuiltin,
    alt: "Custom basement built-in cabinet with walnut counter by Walkercraft Carpentry",
  },
  {
    caption: "Canoe paddles — handcrafted",
    tag: "Woodworking",
    image: canoePaddles,
    alt: "Four handcrafted multi-wood canoe paddles by Walkercraft Carpentry",
  },
  {
    caption: "Custom coffee table — staining",
    tag: "Woodworking",
    image: coffeeTableStaining,
    alt: "Mid-century modern coffee table being stained by Walkercraft Carpentry",
  },
  {
    caption: "Coffee table — installed",
    tag: "Woodworking",
    image: coffeeTableFinished,
    alt: "Custom mid-century coffee table in living room by Walkercraft Carpentry",
