---
import { getCMSContent, cms } from '@lib/cms';
const c = await getCMSContent();
---

<section class="py-12 md:py-16 bg-parchment-dark border-y border-warmgray-300/40">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <blockquote class="text-center max-w-2xl mx-auto mb-8">
      <p class="text-lg md:text-xl text-bark italic leading-relaxed">
        {cms(c, 'testimonial_quote', "\u201CBrett did an incredible job on our deck. On time, on budget, and the quality speaks for itself. Wouldn\u2019t hesitate to recommend Walkercraft Carpentry.\u201D")}
      </p>
      <footer class="mt-3 text-sm text-warmgray-600">&mdash; {cms(c, 'testimonial_attribution', 'Homeowner, Hamilton')}</footer>
    </blockquote>

    <div class="flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm text-warmgray-600">
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-forest" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        {cms(c, 'trust_badge_1', 'Fully Insured')}
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-forest" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        {cms(c, 'trust_badge_2', 'Locally Owned')}
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-forest" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        {cms(c, 'trust_badge_3', 'Free Estimates')}
      </span>
    </div>
  </div>
</section>
