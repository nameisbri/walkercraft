---
const cities = ["Hamilton", "Burlington", "Oakville", "Ancaster", "Dundas", "Stoney Creek", "Other"];
---

<section id="contact" class="py-20 md:py-32 bg-parchment-dark">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_1.2fr] gap-12 md:gap-20 items-start">
      <div class="md:sticky md:top-28">
        <p class="text-gold font-semibold text-sm tracking-widest uppercase mb-4">Contact</p>
        <h2 class="font-display text-4xl md:text-5xl mb-6">Get a Free Estimate</h2>
        <p class="text-warmgray-600 text-lg leading-relaxed mb-8">
          Tell us about your project and we'll get back to you within 24 hours.
        </p>
        <div class="hidden md:block space-y-4 text-warmgray-600">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+15551234567" class="hover:text-gold transition-colors">(555) 123-4567</a>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:brett@walkercraft.ca" class="hover:text-gold transition-colors">brett@walkercraft.ca</a>
          </div>
        </div>
      </div>

      <form id="contact-form" class="bg-white rounded-sm border border-warmgray-300/60 p-6 md:p-8 space-y-5">
        <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
        <input type="hidden" name="subject" value="New Walkercraft Lead" />

        <div>
          <label for="name" class="block text-sm font-semibold mb-1.5 text-bark">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full border border-warmgray-300 rounded-sm px-4 py-3 text-base focus:outline-none focus:ring-2 focus:ring-gold/40 focus:border-gold bg-parchment/50"
            placeholder="Your full name"
          />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="phone" class="block text-sm font-semibold mb-1.5 text-bark">Phone</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              class="w-full border border-warmgray-300 rounded-sm px-4 py-3 text-base focus:outline-none focus:ring-2 focus:ring-gold/40 focus:border-gold bg-parchment/50"
              placeholder="(555) 123-4567"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold mb-1.5 text-bark">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full border border-warmgray-300 rounded-sm px-4 py-3 text-base focus:outline-none focus:ring-2 focus:ring-gold/40 focus:border-gold bg-parchment/50"
              placeholder="you@example.com"
            />
          </div>
        </div>

        <div>
          <label for="city" class="block text-sm font-semibold mb-1.5 text-bark">City</label>
          <select
            id="city"
            name="city"
            required
            class="w-full border border-warmgray-300 rounded-sm px-4 py-3 text-base focus:outline-none focus:ring-2 focus:ring-gold/40 focus:border-gold bg-parchment/50"
          >
            <option value="" disabled selected>Select your city</option>
            {cities.map((city) => (
              <option value={city}>{city}</option>
            ))}
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-semibold mb-1.5 text-bark">Tell us about your project</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            required
            class="w-full border border-warmgray-300 rounded-sm px-4 py-3 text-base focus:outline-none focus:ring-2 focus:ring-gold/40 focus:border-gold bg-parchment/50 resize-y"
            placeholder="Describe what you need help with..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-gold text-white font-semibold px-6 py-4 rounded-sm text-base hover:bg-gold-light transition-colors"
        >
          Send My Request
        </button>

        <div id="form-status" class="hidden text-center py-3 rounded-sm text-sm font-semibold"></div>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const status = document.getElementById("form-status")!;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = "Sending...";

    try {
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: new FormData(form),
      });
      const data = await response.json();

      if (data.success) {
        status.textContent = "Thanks! We'll be in touch within 24 hours.";
        status.className = "text-center py-3 rounded-sm text-sm font-semibold bg-green-50 text-green-900 border border-green-200";
        form.reset();
      } else {
        throw new Error("Submission failed");
      }
    } catch {
      status.textContent = "Something went wrong. Please call us instead.";
      status.className = "text-center py-3 rounded-sm text-sm font-semibold bg-red-50 text-red-900 border border-red-200";
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Send My Request";
    }
  });
</script>
